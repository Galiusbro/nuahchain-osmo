{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launch osmosisd",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "cmd/osmosisd/main.go",
      "args": [
        "start",
        "--log_level", "debug"
      ],
      "cwd": "${workspaceFolder}",
      "env": {},
      "console": "integratedTerminal"
    },
    {
      "name": "Test Current Package",
      "type": "go",
      "request": "launch",
      "mode": "test",
      "program": "${workspaceFolder}",
      "args": [
        "-test.v"
      ],
      "cwd": "${fileDirname}",
      "console": "integratedTerminal"
    },
    {
      "name": "Debug Current Test",
      "type": "go",
      "request": "launch",
      "mode": "test",
      "program": "${fileDirname}",
      "args": [
        "-test.run",
        "${input:testName}"
      ],
      "console": "integratedTerminal"
    }
  ],
  "inputs": [
    {
      "id": "testName",
      "description": "Test function name",
      "default": "",
      "type": "promptString"
    }
  ]
}